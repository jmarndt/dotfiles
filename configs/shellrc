export LESSHISTFILE=$HOME/.lesshst

source $HOME/dotfiles/dotfiles.context

if [[ $SHELL = "/bin/zsh" ]]; then
    export SYSTEM_RC="$HOME/.zshrc"
    [[ $IS_SERVER = "false" ]] && source $HOME/dotfiles/configs/zshrc
fi
if [[ $SHELL = "/bin/bash" ]]; then
    export SYSTEM_RC="$HOME/.bashrc"
    [[ $IS_SERVER = "false" ]] && source $HOME/dotfiles/configs/bashrc
fi

source $HOME/dotfiles/configs/functions
source $HOME/dotfiles/configs/aliases

[[ -z "$TMUX" ]] && (tmux attach -t $(hostname) || tmux new -s $(hostname))
